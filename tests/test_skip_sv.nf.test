nextflow_pipeline {

    name "Test pipeline: NFCORE_PACSOMATIC"
    script "../main.nf"
    tag "pipeline"
    tag "nfcore_pacsomatic"
    tag "test_skip_sv"
    profile "test_skip_sv"

    test("-profile test_skip_sv") {

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    path("$outputDir/alignment/").list(),
                    path("$outputDir/germline_snv/").list(),
                    path("$outputDir/somatic_snv/deepsomatic/").list(),
                    path("$outputDir/somatic_cnv/").list(),
                    path("$outputDir/pipeline_info/nf_core_pacsomatic_software_mqc_versions.yml")
                ).match() }
            )
        }
    }
}

nextflow_pipeline {

    name "Test pipeline: NFCORE_PACSOMATIC"
    script "../main.nf"
    tag "pipeline"
    tag "nfcore_pacsomatic"
    tag "test_minimal"
    profile "test_minimal"

    test("-profile test_minimal") {

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    path("$outputDir/alignment/pbmm2/").list(),
                    path("$outputDir/germline_snv/clair3/").list(),
                    path("$outputDir/somatic_snv/deepsomatic/").list(),
                    path("$outputDir/pipeline_info/nf_core_pacsomatic_software_mqc_versions.yml")
                ).match() }
            )
        }
    }
}
